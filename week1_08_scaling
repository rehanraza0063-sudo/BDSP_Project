# Get the segment of the signal we were working with
signal_segment_for_scaling = record.p_signal[start_sample:end_sample, 0]

# Define the scaling factor
scaling_factor = 1.5 # You can change this value (e.g., 0.5 for reduction, 2.0 for amplification)

# Apply the scaling factor to the signal segment
scaled_signal_segment = signal_segment_for_scaling * scaling_factor

# Plot the original and scaled signals
plt.figure(figsize=(15, 6))
plt.plot(signal_segment_for_scaling, label='Original Signal Segment')
plt.plot(scaled_signal_segment, label=f'Scaled Signal (Factor: {scaling_factor})', linestyle='--')
plt.title(f'Original vs. Scaled Signal Segment from {record_name} (Lead {record.sig_name[0]})')
plt.xlabel('Sample Index')
plt.ylabel(f'Amplitude ({record.units[0]})')
plt.grid(True)
plt.legend()
plt.show()
